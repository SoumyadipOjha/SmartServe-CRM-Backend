PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/flayx?retryWrites=true&w=majority

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

# JWT — use a strong random secret (openssl rand -hex 64)
JWT_SECRET=

# Unsubscribe HMAC secret — use a strong random secret (openssl rand -hex 32)
UNSUB_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Allowed frontend origin(s) — comma-separated for multiple
CLIENT_URL=https://app.yourdomain.com

# Your backend public URL (used in tracking pixels and unsubscribe links)
BASE_URL=https://api.yourdomain.com

# Email — Resend
RESEND_API_KEY=
# Must be a verified domain sender in Resend dashboard
EMAIL_FROM=Flayx <noreply@yourdomain.com>
