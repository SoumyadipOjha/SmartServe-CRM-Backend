{
  "swagger": "2.0",
  "info": {
    "title": "SmartServe CRM API",
    "description": "REST API for the SmartServe CRM platform — customers, orders, campaigns, tasks, pipeline deals, email tracking, push notifications, and more.",
    "version": "2.0.0"
  },
  "basePath": "/api",
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT token in the format: Bearer <token>"
    }
  },
  "paths": {
    "/auth/google": {
      "get": {
        "tags": ["Auth"],
        "summary": "Initiate Google OAuth login",
        "responses": {
          "302": { "description": "Redirect to Google OAuth consent screen" }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Google OAuth callback — receives code, returns JWT via redirect",
        "responses": {
          "302": { "description": "Redirect to CLIENT_URL/auth/success?token=<jwt>" },
          "401": { "description": "Authentication failed" }
        }
      }
    },
    "/auth/demo": {
      "post": {
        "tags": ["Auth"],
        "summary": "Demo login — creates or reuses the shared demo account and seeds sample data",
        "description": "No credentials required. Returns a valid JWT for `demo@flayx.app` with pre-seeded customers, orders, and campaigns so reviewers can explore the app immediately.",
        "responses": {
          "200": {
            "description": "JWT token and user object",
            "schema": {
              "type": "object",
              "properties": {
                "token": { "type": "string" },
                "user":  { "$ref": "#/definitions/User" }
              }
            }
          },
          "500": { "description": "Demo login failed" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the currently authenticated user",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "schema": {
              "type": "object",
              "properties": {
                "user": { "$ref": "#/definitions/User" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/customers": {
      "get": {
        "tags": ["Customers"],
        "summary": "List all customers for the authenticated org",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of customer objects" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Customers"],
        "summary": "Create a new customer",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/CustomerInput" }
          }
        ],
        "responses": {
          "201": { "description": "Customer created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/customers/{id}": {
      "get": {
        "tags": ["Customers"],
        "summary": "Get a single customer by ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Customer object" },
          "404": { "description": "Customer not found" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "tags": ["Customers"],
        "summary": "Update a customer",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/CustomerInput" } }
        ],
        "responses": {
          "200": { "description": "Updated customer" },
          "404": { "description": "Customer not found" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Customers"],
        "summary": "Delete a customer",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Customer deleted" },
          "404": { "description": "Customer not found" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/customers/{customerId}/tasks": {
      "get": {
        "tags": ["Tasks"],
        "summary": "List all tasks for a specific customer",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "customerId", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Array of task objects" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Tasks"],
        "summary": "Create a task for a customer",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "customerId", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/TaskInput" } }
        ],
        "responses": {
          "201": { "description": "Task created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/customers/{customerId}/tasks/{taskId}": {
      "patch": {
        "tags": ["Tasks"],
        "summary": "Update a task (mark complete, change due date, etc.)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "customerId", "in": "path", "required": true, "type": "string" },
          { "name": "taskId", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/TaskInput" } }
        ],
        "responses": {
          "200": { "description": "Updated task" },
          "404": { "description": "Task not found" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Delete a task",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "customerId", "in": "path", "required": true, "type": "string" },
          { "name": "taskId", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Task deleted" },
          "404": { "description": "Task not found" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/tasks": {
      "get": {
        "tags": ["Tasks"],
        "summary": "List all tasks across all customers for the authenticated user",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of task objects (populated with customer name)" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List all orders",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of order objects" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create a new order",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/OrderInput" } }
        ],
        "responses": {
          "201": { "description": "Order created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/campaigns": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "List all campaigns for the authenticated user",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of campaign objects" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Campaigns"],
        "summary": "Create a new campaign",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/CampaignInput" } }
        ],
        "responses": {
          "201": { "description": "Campaign created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/campaigns/{id}": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "Get a single campaign by ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Campaign object" },
          "404": { "description": "Campaign not found" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/campaigns/{id}/activate": {
      "post": {
        "tags": ["Campaigns"],
        "summary": "Activate a campaign — queues and sends messages to the audience",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Campaign queued for sending" },
          "404": { "description": "Campaign not found" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/campaigns/{id}/stats": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "Get delivery statistics for a campaign including open and click counts",
        "description": "Returns sent, failed, opened, and clicked counters. Open and click counts are updated in real-time via Resend webhooks.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Delivery stats",
            "schema": { "$ref": "#/definitions/DeliveryStats" }
          },
          "404": { "description": "Campaign not found" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/campaigns/audience/preview": {
      "post": {
        "tags": ["Campaigns"],
        "summary": "Preview how many customers match a set of segment rules",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Rules" } }
        ],
        "responses": {
          "200": { "description": "Audience size" },
          "400": { "description": "Invalid rules" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/webhooks/resend": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Resend email event webhook — tracks open and click engagement",
        "description": "Called by Resend when an email is opened, clicked, bounced, or complained about. Signature is verified via HMAC-SHA256 (svix headers). Updates `deliveryStats.opened` and `deliveryStats.clicked` on the associated campaign.",
        "parameters": [
          {
            "name": "svix-id",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "Svix message ID (used for signature verification)"
          },
          {
            "name": "svix-timestamp",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "Unix timestamp (replay-attack guard — rejected if > 5 min old)"
          },
          {
            "name": "svix-signature",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "HMAC-SHA256 signature prefixed with `v1,`"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["type", "data"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["email.opened", "email.clicked", "email.bounced", "email.complained"],
                  "description": "Resend event type"
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "email_id": {
                      "type": "string",
                      "description": "Resend email ID — matches CommunicationLog.resendId"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Event processed" },
          "400": { "description": "Invalid signature or missing fields" },
          "500": { "description": "Processing error" }
        }
      }
    },
    "/push/vapid-key": {
      "get": {
        "tags": ["Push Notifications"],
        "summary": "Get the VAPID public key needed to create a browser push subscription",
        "description": "Public endpoint — no auth required. The frontend calls this before calling `pushManager.subscribe()`.",
        "responses": {
          "200": {
            "description": "VAPID public key",
            "schema": {
              "type": "object",
              "properties": {
                "publicKey": {
                  "type": "string",
                  "description": "URL-safe base64-encoded VAPID public key"
                }
              }
            }
          },
          "503": { "description": "Push notifications not configured (VAPID env vars missing)" }
        }
      }
    },
    "/push/subscribe": {
      "post": {
        "tags": ["Push Notifications"],
        "summary": "Register a browser push subscription for the authenticated user",
        "description": "Stores the `PushSubscription` object returned by `pushManager.subscribe()`. Idempotent — safe to call on every app load.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/PushSubscriptionInput" }
          }
        ],
        "responses": {
          "201": { "description": "Subscription registered" },
          "400": { "description": "Invalid subscription object" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/push/unsubscribe": {
      "post": {
        "tags": ["Push Notifications"],
        "summary": "Remove a push subscription for the authenticated user",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["endpoint"],
              "properties": {
                "endpoint": { "type": "string", "description": "Subscription endpoint URL" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Subscription removed" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/ai/convert-rules": {
      "post": {
        "tags": ["AI"],
        "summary": "Convert a natural language description into segment rules",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["description"],
              "properties": {
                "description": { "type": "string", "example": "Customers who spent over $1000 in the last 30 days" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Converted rules object" },
          "400": { "description": "Invalid description" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "AI conversion failed" }
        }
      }
    },
    "/ai/generate-message": {
      "post": {
        "tags": ["AI"],
        "summary": "Generate a promotional campaign message from a goal description",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["goal"],
              "properties": {
                "goal": { "type": "string", "example": "Win back dormant users with a discount" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Generated message text" },
          "400": { "description": "Invalid goal" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "AI generation failed" }
        }
      }
    }
  },
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "_id":   { "type": "string" },
        "name":  { "type": "string" },
        "email": { "type": "string" },
        "role":  { "type": "string", "enum": ["admin", "user"] },
        "teamRole": { "type": "string", "enum": ["owner", "admin", "member"] },
        "picture": { "type": "string" }
      }
    },
    "CustomerInput": {
      "type": "object",
      "required": ["name", "email"],
      "properties": {
        "name":         { "type": "string" },
        "email":        { "type": "string" },
        "phone":        { "type": "string" },
        "totalSpend":   { "type": "number" },
        "visits":       { "type": "number" },
        "lastActivity": { "type": "string", "format": "date-time" }
      }
    },
    "TaskInput": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title":       { "type": "string" },
        "description": { "type": "string" },
        "dueDate":     { "type": "string", "format": "date-time" },
        "priority":    { "type": "string", "enum": ["low", "medium", "high"] },
        "completed":   { "type": "boolean" }
      }
    },
    "Task": {
      "type": "object",
      "properties": {
        "_id":            { "type": "string" },
        "title":          { "type": "string" },
        "description":    { "type": "string" },
        "dueDate":        { "type": "string", "format": "date-time" },
        "priority":       { "type": "string", "enum": ["low", "medium", "high"] },
        "completed":      { "type": "boolean" },
        "reminderSentAt": {
          "type": "string",
          "format": "date-time",
          "description": "Set when the 24-hour due-date reminder email was sent. Null until then."
        },
        "customer":  { "type": "string", "description": "Customer ID" },
        "createdBy": { "type": "string", "description": "User ID" }
      }
    },
    "OrderInput": {
      "type": "object",
      "required": ["customer", "amount", "products"],
      "properties": {
        "customer": { "type": "string", "description": "Customer ID" },
        "amount":   { "type": "number" },
        "status":   { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "products": {
          "type": "array",
          "items": { "$ref": "#/definitions/Product" }
        },
        "orderDate": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "type": "object",
      "required": ["name", "price", "quantity"],
      "properties": {
        "name":     { "type": "string" },
        "price":    { "type": "number" },
        "quantity": { "type": "number" }
      }
    },
    "CampaignInput": {
      "type": "object",
      "required": ["name", "message"],
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "rules":       { "$ref": "#/definitions/Rules" },
        "message":     { "type": "string" }
      }
    },
    "DeliveryStats": {
      "type": "object",
      "description": "Real-time delivery counters updated by the campaign scheduler and Resend webhooks",
      "properties": {
        "sent":    { "type": "integer", "description": "Emails successfully sent" },
        "failed":  { "type": "integer", "description": "Emails that failed to deliver" },
        "opened":  { "type": "integer", "description": "Unique opens tracked via Resend webhook (email.opened)" },
        "clicked": { "type": "integer", "description": "Unique link clicks tracked via Resend webhook (email.clicked)" }
      }
    },
    "Rules": {
      "type": "object",
      "required": ["conditions", "condition"],
      "properties": {
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/Condition" }
        },
        "condition": { "type": "string", "enum": ["AND", "OR"] }
      }
    },
    "Condition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field":    { "type": "string", "enum": ["totalSpend", "visits", "lastActivity"] },
        "operator": { "type": "string", "enum": [">", "<", ">=", "<=", "=", "!=", "contains"] },
        "value":    { "type": "string" }
      }
    },
    "PushSubscriptionInput": {
      "type": "object",
      "required": ["endpoint", "keys"],
      "description": "The PushSubscription object returned by the browser's pushManager.subscribe()",
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "Browser-assigned push endpoint URL"
        },
        "keys": {
          "type": "object",
          "required": ["p256dh", "auth"],
          "properties": {
            "p256dh": { "type": "string", "description": "Elliptic-curve Diffie-Hellman public key (base64url)" },
            "auth":   { "type": "string", "description": "Authentication secret (base64url)" }
          }
        }
      }
    }
  }
}
