PORT=5000
NODE_ENV=development

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/smartserve-crm

# Google OAuth 2.0 (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT signing secret — any long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (used for CORS and OAuth redirects)
CLIENT_URL=http://localhost:3000

# Resend email delivery (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret_here  # optional, from Resend dashboard
EMAIL_FROM=Flayx <onboarding@resend.dev>
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# VAPID keys for Web Push Notifications — generate once with: node -e "const w=require('web-push'); console.log(JSON.stringify(w.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@yourapp.com
